# Conscience Os — environment variables
# Copy to .env.local for development. Configure in Vercel / Railway env panel for deploys.

# === DATABASE (REQUIRED for /app and CRM features) ===
# Postgres connection string. Recommended: Neon free tier (zero spend, instant on Vercel Marketplace).
# Local dev: pull from Vercel with `vercel env pull .env.local` after provisioning.
DATABASE_URL=

# === AUTH (REQUIRED for /app to work) ===
# JWT signing secret. Generate with: openssl rand -base64 48
JWT_SECRET=

# Operator login. The single admin who can sign in to /app.
ADMIN_EMAIL=
# Hash a password with: node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
ADMIN_PASSWORD_HASH=

# === EMAIL (Resend, optional) ===
# Get key at: https://resend.com/api-keys
# Drives transactional email on /api/lead (internal inbox copy + confirmation to submitter).
RESEND_API_KEY=

# Where intake submissions land. Defaults to hello@conscienceos.com.
LEAD_INBOX=

# Sender identity. Use a verified Resend domain. Default is Resend's onboarding domain.
LEAD_FROM=

# === LEAD ROUTING (Discord, optional) ===
# If set, every intake gets posted to this Discord webhook (separate channel recommended).
LEAD_DISCORD_WEBHOOK=

# === ERROR TRACKING (Sentry, optional, M2) ===
SENTRY_DSN_WEB=
SENTRY_DSN_API=

# === ANALYTICS (deferred to M2) ===
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=conscienceos.com
# NEXT_PUBLIC_PLAUSIBLE_API_HOST=https://plausible.example.com

# === BOOKING (Cal.com, optional) ===
# CAL_COM_API_KEY=
# CAL_COM_WEBHOOK_SECRET=

# === AI (Anthropic, deferred to first paying client) ===
# ANTHROPIC_API_KEY=
